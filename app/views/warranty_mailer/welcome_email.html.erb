<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background: linear-gradient(135deg, #2b8cee 0%, #1a6bce 100%);
        color: white;
        padding: 40px;
        border-radius: 12px 12px 0 0;
        text-align: center;
      }
      .header h1 {
        margin: 0;
        font-size: 28px;
      }
      .content {
        background: #fff;
        padding: 40px 30px;
        border: 1px solid #e1e4e8;
        border-top: none;
      }
      .welcome-box {
        background: #e7f3ff;
        border: 2px dashed #2b8cee;
        padding: 25px;
        margin: 20px 0;
        border-radius: 8px;
        text-align: center;
      }
      .features {
        margin: 30px 0;
      }
      .feature {
        display: flex;
        align-items: center;
        margin: 15px 0;
        padding: 15px;
        background: #f8f9fa;
        border-radius: 8px;
      }
      .feature-icon {
        font-size: 24px;
        margin-right: 15px;
      }
      .cta-button {
        display: inline-block;
        background: #2b8cee;
        color: white;
        padding: 14px 40px;
        text-decoration: none;
        border-radius: 8px;
        margin-top: 20px;
        font-weight: 600;
        font-size: 16px;
      }
      .footer {
        text-align: center;
        padding: 20px;
        color: #666;
        font-size: 14px;
        border-top: 1px solid #e1e4e8;
        margin-top: 30px;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h1>🎉 Welcome to Warranty Vault!</h1>
    </div>
    
    <div class="content">
      <p>Hi <%= @user.full_name %>,</p>
      
      <p>Thank you for joining Warranty Vault! We're here to help you keep track of all your purchases and warranties in one secure place.</p>
      
      <div class="welcome-box">
        <h2>📦 Your Digital Receipt Vault</h2>
        <p>Never lose a receipt or miss a warranty deadline again!</p>
      </div>
      
      <div class="features">
        <h3>What you can do:</h3>
        
        <div class="feature">
          <span class="feature-icon">📸</span>
          <div>
            <strong>Upload Receipts</strong>
            <p style="margin: 0; color: #666; font-size: 14px;">Scan or upload your receipts and invoices</p>
          </div>
        </div>
        
        <div class="feature">
          <span class="feature-icon">🔔</span>
          <div>
            <strong>Smart Reminders</strong>
            <p style="margin: 0; color: #666; font-size: 14px;">Get notified before warranties expire</p>
          </div>
        </div>
        
        <div class="feature">
          <span class="feature-icon">📧</span>
          <div>
            <strong>Gmail Integration</strong>
            <p style="margin: 0; color: #666; font-size: 14px;">Auto-import receipts from your inbox</p>
          </div>
        </div>
        
        <div class="feature">
          <span class="feature-icon">🔒</span>
          <div>
            <strong>Secure Storage</strong>
            <p style="margin: 0; color: #666; font-size: 14px;">Your data is encrypted and private</p>
          </div>
        </div>
      </div>
      
      <a href="<%= ENV.fetch('FRONTEND_URL', 'http://localhost:5173') %>/dashboard" class="cta-button">
        Get Started
      </a>
    </div>
    
    <div class="footer">
      <p>© <%= Date.current.year %> Warranty Vault. All rights reserved.</p>
      <p>Questions? Reply to this email or visit our help center.</p>
    </div>
  </body>
</html>
