<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        padding: 30px;
        border-radius: 12px 12px 0 0;
        text-align: center;
      }
      .header h1 {
        margin: 0;
        font-size: 24px;
      }
      .content {
        background: #fff;
        padding: 30px;
        border: 1px solid #e1e4e8;
        border-top: none;
      }
      .alert-box {
        background: #f8d7da;
        border-left: 4px solid #dc3545;
        padding: 20px;
        margin: 20px 0;
        border-radius: 4px;
      }
      .product-info {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
        margin: 20px 0;
      }
      .product-info h3 {
        margin-top: 0;
        color: #dc3545;
      }
      .cta-button {
        display: inline-block;
        background: #dc3545;
        color: white;
        padding: 12px 30px;
        text-decoration: none;
        border-radius: 6px;
        margin-top: 20px;
        font-weight: 600;
      }
      .footer {
        text-align: center;
        padding: 20px;
        color: #666;
        font-size: 14px;
        border-top: 1px solid #e1e4e8;
        margin-top: 30px;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h1>❌ Warranty Expired</h1>
    </div>
    
    <div class="content">
      <p>Hi <%= @user.full_name %>,</p>
      
      <p>Your warranty has expired. You may want to consider renewal options or replacement plans.</p>
      
      <div class="alert-box">
        <strong>⚠️ Warranty coverage has ended</strong>
      </div>
      
      <div class="product-info">
        <h3><%= @invoice.product_name %></h3>
        <p><strong>Brand:</strong> <%= @invoice.brand || "N/A" %></p>
        <p><strong>Purchase Date:</strong> <%= @invoice.purchase_date.strftime("%B %d, %Y") %></p>
        <p><strong>Warranty Expired:</strong> <%= @invoice.expires_at.strftime("%B %d, %Y") %></p>
        <p><strong>Amount:</strong> <%= @invoice.formatted_amount %></p>
      </div>
      
      <p>Check if extended warranty or protection plans are available for this product.</p>
      
      <a href="<%= ENV.fetch('FRONTEND_URL', 'http://localhost:5173') %>/invoices/<%= @invoice.id %>" class="cta-button">
        View Details
      </a>
    </div>
    
    <div class="footer">
      <p>© <%= Date.current.year %> Warranty Vault. All rights reserved.</p>
      <p>You're receiving this email because you have warranty alerts enabled.</p>
    </div>
  </body>
</html>
